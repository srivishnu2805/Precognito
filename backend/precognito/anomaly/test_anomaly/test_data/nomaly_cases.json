    },
    {
      "name": "Critical Values",
      "input": {
        "machine_id": "ANOM-005",
        "temperature": 335.0,
        "vibration": 3500.0,
        "torque": 5.0,
        "type": "L"
      },
      "expected": {
        "anomaly_detected": true,
        "severity": "HIGH",
        "confidence_min": 0.7,
        "anomaly_types": ["ML_Detected"]
