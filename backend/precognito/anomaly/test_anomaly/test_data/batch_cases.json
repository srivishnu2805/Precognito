{
  "description": "Batch processing test cases - mixed normal and anomaly data",
  "test_cases": [
    {
      "name": "Mixed Normal and Anomaly",
      "input": {
        "data": [
          {
            "machine_id": "BATCH-001",
            "temperature": 300.0,
            "vibration": 1500.0,
            "torque": 40.0,
            "type": "M"
          },
          {
            "machine_id": "BATCH-002",
            "temperature": 325.0,
            "vibration": 1500.0,
            "torque": 40.0,
            "type": "M"
          },
          {
            "machine_id": "BATCH-003",
            "temperature": 300.0,
            "vibration": 3000.0,
            "torque": 10.0,
            "type": "L"
          }
        ]
      },
      "expected": {
        "total_items": 3,
        "anomalies_detected": 2,
        "normal_detected": 1,
        "pattern_detection": true,
        "ml_detection": true
      }
    },
    {
